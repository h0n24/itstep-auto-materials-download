{
  "manifest_version": 3,
  "name": "IT Step Materials Downloader",
  "version": "1.5",
  "description": "Collect direct material links from lb.itstep.org/materials and export them as an HTML index or ZIP archive.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://lb.itstep.org/*",
    "https://fsx1.itstep.org/*",
    "https://materials.itstep.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "IT Step Materials",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://lb.itstep.org/materials*"
      ],
      "js": [
        "shared.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared.js",
        "offscreen.html",
        "offscreen.js",
        "lib/zip.js"
      ],
      "matches": [
        "https://lb.itstep.org/*"
      ]
    }
  ]
}
